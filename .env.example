# Core service URLs. With the bundled profile, use the Docker service names below.
PROWLARR_URL=http://prowlarr:9696
PROWLARR_API_KEY=replace-me
SEERR_URL=http://seerr:5055
SEERR_API_KEY=replace-me

# Enable one or both providers. Never commit the populated .env file.
PROVIDERS=torbox,alldebrid
TORBOX_TOKEN=
ALLDEBRID_TOKEN=

# Resolution policy
QUALITIES=2160p,1080p
MIN_SEEDERS=1
MAX_RESULTS_PER_QUALITY=20
ALLOW_UNCACHED=false
RESOLVE_TIMEOUT=15m
STREAM_URL_TTL=45m
SEERR_POLL_INTERVAL=2m

# Host directory mounted into Plex as a library root.
MEDIA_MOUNT=./mnt
PUID=1000
PGID=1000
TZ=America/Chicago

