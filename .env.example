# Seerr request source. With the bundled profile, use the Docker service name below.
SEERR_URL=http://seerr:5055
SEERR_API_KEY=replace-me

# Direct Stremio-compatible scraper endpoints, separated by commas.
# Format: name|<configured manifest URL>. Keep debrid credentials out of addon URLs;
# WatchTower performs its own TorBox/AllDebrid cache checks and link generation.
STREMIO_ADDONS=torrentio|https://torrentio.strem.fun/manifest.json
# Examples for self-hosted services:
# STREMIO_ADDONS=torrentio|https://torrentio.strem.fun/manifest.json,comet|http://comet:8000/manifest.json,stremthru|http://stremthru:8080/your-config/manifest.json

# Enable one or both providers. Never commit the populated .env file.
PROVIDERS=torbox,alldebrid
TORBOX_TOKEN=
ALLDEBRID_TOKEN=

# Resolution policy
QUALITIES=2160p,1080p
MIN_SEEDERS=0
MAX_RESULTS_PER_QUALITY=20
ALLOW_UNCACHED=false
RESOLVE_TIMEOUT=15m
STREAM_URL_TTL=45m
SEERR_POLL_INTERVAL=2m

# Host directory mounted into Plex as a library root.
MEDIA_MOUNT=./mnt
TZ=America/Chicago
